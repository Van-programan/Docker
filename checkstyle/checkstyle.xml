<?xml version="1.0"?>
<!DOCTYPE module PUBLIC
        "-//Checkstyle//DTD Checkstyle Configuration 1.3//EN"
        "https://checkstyle.org/dtds/configuration_1_3.dtd">

<module name="Checker">
    <property name="charset" value="UTF-8"/>
    <property name="severity" value="error"/>
    <property name="fileExtensions" value="java, properties, xml"/>

    <module name="LineLength">
        <property name="max" value="120"/>
        <property name="ignorePattern" value="^package.*|^import.*|a href|href|http://|https://|ftp://"/>
    </module>

    <module name="TreeWalker">

        <module name="IllegalImport"/>
        <module name="RedundantImport"/>
        <module name="UnusedImports">
            <property name="processJavadoc" value="false"/>
            <message key="import.unused" value="Неиспользуемый импорт: {0}"/>
        </module>

        <module name="WhitespaceAfter">
            <property name="tokens" value="COMMA, SEMI, TYPECAST"/>
            <message key="ws.notFollowed" value="После '{0}' должен быть пробел"/>
        </module>

        <module name="ModifierOrder">
            <message key="mod.order" value="Неверный порядок модификаторов: {0}"/>
        </module>

        <module name="RedundantModifier">
            <message key="redundantModifier" value="Лишний модификатор: {0}"/>
        </module>

        <module name="LeftCurly">
            <property name="option" value="eol"/>
            <property name="tokens" value="CLASS_DEF, INTERFACE_DEF, ENUM_DEF, METHOD_DEF, CTOR_DEF"/>
            <message key="line.break.after" value="Открывающая скобка должна быть на той же строке"/>
        </module>

        <module name="TypeName">
            <property name="format" value="^[A-Z][a-zA-Z0-9]*$"/>
            <message key="name.invalidPattern" value="Имя класса {0} должно начинаться с заглавной буквы"/>
        </module>

        <module name="MethodName">
            <property name="format" value="^[a-z][a-zA-Z0-9]*$"/>
            <message key="name.invalidPattern" value="Имя метода {0} должно начинаться со строчной буквы"/>
        </module>

        <module name="MemberName">
            <property name="format" value="^[a-z][a-zA-Z0-9]*$"/>
            <message key="name.invalidPattern" value="Имя поля {0} должно начинаться со строчной буквы"/>
        </module>

        <module name="ParameterName">
            <property name="format" value="^[a-z][a-zA-Z0-9]*$"/>
            <message key="name.invalidPattern" value="Имя параметра {0} должно начинаться со строчной буквы"/>
        </module>

        <module name="ConstantName">
            <property name="format" value="^[A-Z][A-Z0-9]*(_[A-Z0-9]+)*$"/>
            <message key="name.invalidPattern" value="Имя константы {0} должно быть в верхнем регистре с подчёркиваниями"/>
        </module>

        <!-- 12. Специальные правила для Lombok -->
        <!-- Игнорируем Lombok аннотации при проверке -->
        <module name="SuppressionCommentFilter">
            <property name="offCommentFormat" value="@lombok\.Getter|lombok\.Setter|lombok\.Data"/>
            <property name="onCommentFormat" value="END GENERATED CODE"/>
        </module>

    </module>
</module>